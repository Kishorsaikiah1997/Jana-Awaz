import React, { useState, useEffect, useMemo } from 'react';
import { db } from './firebase';
import { collection, doc, updateDoc, onSnapshot, addDoc, query, orderBy, limit, getDocs } from 'firebase/firestore';
import { MapContainer, TileLayer, CircleMarker, Popup } from 'react-leaflet';
import 'leaflet/dist/leaflet.css';
import {
  BarChart, Bar, XAxis, YAxis, Tooltip, ResponsiveContainer,
  LineChart, Line, PieChart, Pie, Cell
} from 'recharts';
import { 
  ArrowLeft, Search, Filter, MapPin, CheckCircle, 
  AlertTriangle, Clock, FileText, MessageSquare, Download, TrendingUp,
  RefreshCcw, Share, Users, Target, Activity, ChevronDown, ChevronUp, Share2
} from 'lucide-react';
import { Link } from 'react-router-dom';
import AnalyticsTab from './AnalyticsTab';
import MapTab from './MapTab';

const URGENCY_COLORS: Record<string, string> = {
  'Critical': '#C62828',
  'High': '#E65100',
  'Medium': '#1A237E',
  'Low': '#2E7D32'
};

export default function Dashboard() {
  const [submissions, setSubmissions] = useState<any[]>([]);
  const [loading, setLoading] = useState(true);
  const [activeTab, setActiveTab] = useState<'live'|'analytics'|'map'>('live');
  const [activeAnalyticsSection, setActiveAnalyticsSection] = useState<'priorities'|'themes'|'sentiment'|'report'>('priorities');
  const [mpLanguage, setMpLanguage] = useState(() => localStorage.getItem("mp_language") || "English");

  // Filters
  const [filterCategory, setFilterCategory] = useState("All");
  const [filterUrgency, setFilterUrgency] = useState("All");
  const [filterDate, setFilterDate] = useState("All Time");
  const [filterState, setFilterState] = useState("All");
  const [filterDistrict, setFilterDistrict] = useState("All");
  const [searchTerm, setSearchTerm] = useState("");
  const [showOnlyWithNotes, setShowOnlyWithNotes] = useState(false);
  const [filterSafetyFlagged, setFilterSafetyFlagged] = useState(false);

  // States for Notes and UI
  const [editingNoteId, setEditingNoteId] = useState<string | null>(null);
  const [noteText, setNoteText] = useState("");
  const [fullscreenPhoto, setFullscreenPhoto] = useState<any | null>(null);

  // Priority Ranking State
  const [priorityData, setPriorityData] = useState<any>(null);
  const [isGeneratingPriorities, setIsGeneratingPriorities] = useState(false);
  const [priorityHistory, setPriorityHistory] = useState<any[]>([]);
  const [showPriorityHistory, setShowPriorityHistory] = useState(false);
  const [expandedPriorities, setExpandedPriorities] = useState<Set<string>>(new Set());

  // Theme Clustering State
  const [themesData, setThemesData] = useState<any>(null);
  const [isGeneratingThemes, setIsGeneratingThemes] = useState(false);
  const [themeFilter, setThemeFilter] = useState("All");
  const [expandedThemeIds, setExpandedThemeIds] = useState<Set<string>>(new Set());
  const [mapLayer, setMapLayer] = useState<'urgency' | 'theme'>('urgency');

  // AI Report State
  const [aiReportText, setAiReportText] = useState<string | null>(null);
  const [isGenerating, setIsGenerating] = useState(false);
  const [reportDate, setReportDate] = useState<string>("");

  useEffect(() => {
    localStorage.setItem("mp_language", mpLanguage);
  }, [mpLanguage]);

  useEffect(() => {
    const q = query(collection(db, "submissions"), orderBy("timestamp", "desc"));
    const unsubscribe = onSnapshot(q, (snapshot) => {
      const data: any[] = [];
      snapshot.forEach(doc => {
        data.push({ id: doc.id, ...doc.data() });
      });
      setSubmissions(data);
      setLoading(false);
    }, (error) => {
      console.error("Error fetching submissions:", error);
      setLoading(false);
    });

    // Fetch last report
    const fetchLastReport = async () => {
      const rq = query(collection(db, "mp_reports"), orderBy("generated_at", "desc"), limit(1));
      const rSnap = await getDocs(rq);
      if (!rSnap.empty) {
        const d = rSnap.docs[0].data();
        setAiReportText(d.report_text);
        setReportDate(d.generated_at);
      }
    };
    fetchLastReport();

    // Fetch themes
    const fetchThemes = async () => {
      const tq = query(collection(db, "complaint_themes"), orderBy("generated_at", "desc"), limit(1));
      const tSnap = await getDocs(tq);
      if (!tSnap.empty) {
        setThemesData(tSnap.docs[0].data());
      }
    };
    fetchThemes();

    // Fetch priorities
    const fetchPriorities = async () => {
      const pq = query(collection(db, "priority_rankings"), orderBy("generated_at", "desc"));
      const pSnap = await getDocs(pq);
      if (!pSnap.empty) {
        const history: any[] = [];
        pSnap.forEach(doc => {
          if (doc.id !== 'latest') { // exclude the 'latest' alias doc if it somehow got in the query (usually it doesn't have generated_at unless we set it)
             history.push({ id: doc.id, ...doc.data() });
          }
        });
        if (history.length > 0) {
          setPriorityData(history[0]); // newest
          setPriorityHistory(history);
        }
      }
    };
    fetchPriorities();

    return () => unsubscribe();
  }, []);

  const stats = useMemo(() => {
    const total = submissions.length;
    let todayCount = 0;
    let criticalHighCount = 0;
    let pendingCount = 0;
    let safetyFlagCount = 0;
    
    const today = new Date();
    today.setHours(0,0,0,0);

    submissions.forEach(s => {
      if (new Date(s.timestamp) >= today) todayCount++;
      if (s.urgency === 'Critical' || s.urgency === 'High') criticalHighCount++;
      if (s.status === 'pending') pendingCount++;
      if (s.safety_flagged) safetyFlagCount++;
    });

    let criticalThemes = 0;
    let growingThemes = 0;
    if (themesData && themesData.themes) {
      themesData.themes.forEach((t: any) => {
        if (t.urgency_level === 'Critical') criticalThemes++;
        if (t.trend === 'growing') growingThemes++;
      });
    }

    let criticalActions = 0;
    let activeThemes = 0;
    let citizensImpacted = 0;

    if (priorityData && priorityData.priority_actions) {
      activeThemes = priorityData.total_themes_analyzed || 0;
      priorityData.priority_actions.forEach((a: any) => {
        if (a.urgency === 'Critical') criticalActions++;
        if (a.estimated_affected_population) citizensImpacted += a.estimated_affected_population;
      });
    }

    return { total, today: todayCount, criticalHigh: criticalHighCount, pending: pendingCount, safetyFlags: safetyFlagCount, criticalThemes, growingThemes, criticalActions, activeThemes, citizensImpacted };
  }, [submissions, themesData, priorityData]);

  const filteredSubmissions = useMemo(() => {
    return submissions.filter(s => {
      if (filterSafetyFlagged && !s.safety_flagged) return false;
      if (filterCategory !== "All" && s.category !== filterCategory) return false;
      if (filterUrgency !== "All" && s.urgency !== filterUrgency) return false;
      if (filterState !== "All" && s.state_en !== filterState) return false;
      if (filterDistrict !== "All" && s.district_en !== filterDistrict) return false;
      if (themeFilter !== "All" && s.theme_id !== themeFilter) return false;
      if (showOnlyWithNotes && !s.mp_note) return false;
      if (searchTerm) {
        const textToSearch = (s.text_english || "").toLowerCase();
        if (!textToSearch.includes(searchTerm.toLowerCase())) return false;
      }
      if (filterDate !== "All Time") {
        const d = new Date(s.timestamp);
        const now = new Date();
        if (filterDate === "Today") {
          if (d.toDateString() !== now.toDateString()) return false;
        } else if (filterDate === "This Week") {
          const weekAgo = new Date(now.getTime() - 7 * 24 * 60 * 60 * 1000);
          if (d < weekAgo) return false;
        } else if (filterDate === "This Month") {
          if (d.getMonth() !== now.getMonth() || d.getFullYear() !== now.getFullYear()) return false;
        }
      }
      return true;
    }).sort((a, b) => {
      // Critical always at top if sorted by timestamp descending
      if (a.urgency === 'Critical' && b.urgency !== 'Critical') return -1;
      if (b.urgency === 'Critical' && a.urgency !== 'Critical') return 1;
      return new Date(b.timestamp).getTime() - new Date(a.timestamp).getTime();
    });
  }, [submissions, filterCategory, filterUrgency, filterDate, filterState, filterDistrict, searchTerm, showOnlyWithNotes]);

  const handleStatusUpdate = async (id: string, newStatus: string) => {
    try {
      await updateDoc(doc(db, "submissions", id), { status: newStatus });
    } catch (e) {
      console.error(e);
      alert("Failed to update status");
    }
  };

  const saveNote = async (id: string) => {
    try {
      await updateDoc(doc(db, "submissions", id), {
        mp_note: noteText,
        mp_note_timestamp: new Date().toISOString(),
        mp_note_by: "MP Office",
        status: "noted"
      });
      setEditingNoteId(null);
      setNoteText("");
    } catch (e) {
      console.error(e);
      alert("Failed to save note");
    }
  };

  const generateThemes = async () => {
    setIsGeneratingThemes(true);
    try {
      const sevenDaysAgo = new Date();
      sevenDaysAgo.setDate(sevenDaysAgo.getDate() - 7);
      
      const eligibleComplaints = submissions.filter(s => {
        if (s.moderation_flag === 'blocked') return false;
        return new Date(s.timestamp) >= sevenDaysAgo;
      });

      if (eligibleComplaints.length < 5) {
        alert("Not enough complaints for theme analysis. Themes will appear once more citizens submit complaints. Minimum 5 complaints needed.");
        setIsGeneratingThemes(false);
        return;
      }

      const response = await fetch("/api/generate-themes", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ complaints: eligibleComplaints })
      });

      const result = await response.json();
      
      if (result.success && result.data && result.data.themes) {
        const themeData = result.data;
        
        // STEP 1 - Save to complaint_themes collection
        await addDoc(collection(db, "complaint_themes"), {
          ...themeData,
          generated_at: new Date().toISOString(),
          complaints_analyzed: eligibleComplaints.length,
          constituency: 'assam_demo',
          generation_method: 'gemini_clustering'
        });

        // STEP 2 - Update each complaint document
        for (const theme of themeData.themes) {
          for (const complaintId of theme.complaint_ids) {
            updateDoc(doc(db, "submissions", complaintId), {
              theme_id: theme.theme_id,
              theme_name: theme.theme_name,
              theme_urgency: theme.urgency_level
            }).catch(e => console.error("Error updating complaint theme", e));
          }
        }

        // STEP 3 - Update theme stats
        let criticalThemes = 0;
        let growingThemes = 0;
        for (const theme of themeData.themes) {
          if (theme.urgency_level === 'Critical') criticalThemes++;
          if (theme.trend === 'growing') growingThemes++;
        }
        
        // Use a simple query instead of doc update to avoid needing another setDoc check for simplicity, 
        // Or I can just omit STEP 3 from Dashboard if the themesData already holds everything we need for the UI.
        // Actually I don't need `theme_stats` collection in UI, I can compute criticalThemes directly from `themesData` state!
        
        setThemesData({
           ...themeData,
           generated_at: new Date().toISOString()
        });
      } else {
        alert("Theme analysis unavailable. Gemini API error. Please try again in a few minutes.");
      }
    } catch (error) {
      console.error("Theme generation error:", error);
      alert("Theme analysis unavailable. Gemini API error. Please try again in a few minutes.");
    } finally {
      setIsGeneratingThemes(false);
    }
  };

  const generatePriorities = async () => {
    if (!themesData || !themesData.themes) {
      alert("Please generate themes first before ranking priorities.");
      return;
    }
    
    setIsGeneratingPriorities(true);
    try {
      let safetyCount = 0;
      submissions.forEach(c => {
        if (c.safety_flagged && c.status !== 'resolved') safetyCount++;
      });
      
      const growingThemes = themesData.themes.filter((t: any) => t.trend === 'growing');

      const response = await fetch("/api/generate-priorities", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ 
          themes: themesData.themes, 
          districtData: {}, 
          safetyCount, 
          growingThemes 
        })
      });

      const result = await response.json();
      
      if (result.success && result.data) {
        const pData = result.data;
        
        await addDoc(collection(db, "priority_rankings"), pData);
        
        setPriorityData(pData);
        setPriorityHistory(prev => [pData, ...prev]);
        setActiveTab('priorities');
      } else {
        alert("Failed to generate priorities. " + (result.error || ""));
      }
    } catch (error) {
      console.error("Priority generation error:", error);
      alert("Error calling AI service.");
    } finally {
      setIsGeneratingPriorities(false);
    }
  };

  const generateAIReport = async () => {
    setIsGenerating(true);
    const last7Days = new Date(Date.now() - 7 * 24 * 60 * 60 * 1000);
    const recentSubmissions = submissions.filter(s => new Date(s.timestamp) >= last7Days);
    
    try {
      const res = await fetch("/api/generate-ai-report", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ 
          complaints: recentSubmissions, 
          language: mpLanguage,
          priority_actions: priorityData ? priorityData.priority_actions : []
        })
      });
      const data = await res.json();
      if (data.success) {
        setAiReportText(data.report);
        const timestamp = new Date().toLocaleString();
        setReportDate(timestamp);
        await addDoc(collection(db, "mp_reports"), {
          report_text: data.report,
          generated_at: timestamp,
          complaints_count: recentSubmissions.length,
          date_range: "Last 7 days"
        });
      } else {
        alert("Failed to generate report.");
      }
    } catch (e) {
      console.error(e);
      alert("Error calling AI service.");
    } finally {
      setIsGenerating(false);
    }
  };

  const categories = ["All", ...Array.from(new Set(submissions.map(s => s.category || "Other")))];
  const uniqueStates = ["All", ...Array.from(new Set(submissions.filter(s => s.state_en).map(s => s.state_en)))].sort();
  const uniqueDistricts = ["All", ...Array.from(new Set(submissions.filter(s => s.district_en && (filterState === "All" || s.state_en === filterState)).map(s => s.district_en)))].sort();

  // Analytics Data
  const categoryData = useMemo(() => {
    const counts: Record<string, number> = {};
    submissions.forEach(s => { counts[s.category || 'Other'] = (counts[s.category || 'Other'] || 0) + 1; });
    return Object.entries(counts).map(([name, count]) => ({ name, count })).sort((a, b) => b.count - a.count);
  }, [submissions]);

  const trendData = useMemo(() => {
    const counts: Record<string, number> = {};
    for (let i = 6; i >= 0; i--) {
      const d = new Date();
      d.setDate(d.getDate() - i);
      counts[d.toLocaleDateString('en-US', { month: 'short', day: 'numeric' })] = 0;
    }
    submissions.forEach(s => {
      const d = new Date(s.timestamp).toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
      if (counts[d] !== undefined) counts[d]++;
    });
    return Object.entries(counts).map(([date, count]) => ({ date, count }));
  }, [submissions]);

  const urgencyData = useMemo(() => {
    const counts: Record<string, number> = { 'Critical': 0, 'High': 0, 'Medium': 0, 'Low': 0 };
    submissions.forEach(s => { if (counts[s.urgency] !== undefined) counts[s.urgency]++; });
    return Object.entries(counts).map(([name, value]) => ({ name, value })).filter(d => d.value > 0);
  }, [submissions]);

  const photoIntelligence = useMemo(() => {
    let photosSubmitted = 0;
    let damageDetected = 0;
    let safetyConcerns = 0;
    let floodRelated = 0;
    let floodCriticalHigh = 0;

    submissions.forEach(s => {
      if (s.photo_url) photosSubmitted++;
      if (s.photo_analysis) {
        if (s.photo_analysis.damage_visible) damageDetected++;
        if (s.photo_analysis.safety_concern) safetyConcerns++;
        if (s.photo_analysis.flood_related) {
          floodRelated++;
          if (s.urgency === 'Critical' || s.urgency === 'High') {
            floodCriticalHigh++;
          }
        }
      }
    });

    return { photosSubmitted, damageDetected, safetyConcerns, floodRelated, floodCriticalHigh };
  }, [submissions]);

  const geographyData = useMemo(() => {
    const counts: Record<string, number> = {};
    submissions.forEach(s => { 
      if (s.district_en) {
        counts[s.district_en] = (counts[s.district_en] || 0) + 1; 
      }
    });
    return Object.entries(counts).map(([name, count]) => ({ name, count })).sort((a, b) => b.count - a.count).slice(0, 10);
  }, [submissions]);

  const formatTimeAgo = (dateStr: string) => {
    const diff = Math.floor((new Date().getTime() - new Date(dateStr).getTime()) / 1000);
    if (diff < 60) return `${diff}s ago`;
    if (diff < 3600) return `${Math.floor(diff/60)}m ago`;
    if (diff < 86400) return `${Math.floor(diff/3600)}h ago`;
    return `${Math.floor(diff/86400)}d ago`;
  };

  return (
    <div className="min-h-screen bg-[#FDF6E3] font-sans text-[#3E2723]">
      {/* Tricolor stripe top */}
      <div className="flex h-[3px] w-full">
        <div className="flex-1 bg-[#FF9933]"></div>
        <div className="flex-1 bg-white"></div>
        <div className="flex-1 bg-[#138808]"></div>
      </div>

      <header className="bg-[#FFFEF7] border-b border-[#E8DCC8] px-4 sm:px-8 py-4 sticky top-0 z-40 shadow-sm">
        <div className="max-w-7xl mx-auto flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4">
          <div className="flex items-center gap-3">
            <Link to="/" className="text-[#1A237E] bg-slate-100 p-2 rounded-full hover:bg-slate-200 transition">
              <ArrowLeft className="w-5 h-5" />
            </Link>
            <div className="flex items-center gap-3">
              <svg viewBox="0 0 500 333" className="w-8 h-6 rounded-sm shadow-sm" preserveAspectRatio="none">
                <rect width="500" height="111" fill="#FF9933"/>
                <rect y="111" width="500" height="111" fill="#FFFFFF"/>
                <rect y="222" width="500" height="111" fill="#138808"/>
                <circle cx="250" cy="166.5" r="45" fill="none" stroke="#000080" strokeWidth="2"/>
                {Array.from({length: 24}).map((_, i) => (
                  <line key={i} x1="250" y1="166.5" x2={250 + 45 * Math.cos(i * 15 * Math.PI / 180)} y2={166.5 + 45 * Math.sin(i * 15 * Math.PI / 180)} stroke="#000080" strokeWidth="1"/>
                ))}
              </svg>
              <div>
                <h1 className="font-black text-[#1A237E] text-lg sm:text-xl tracking-tight flex items-center gap-2">
                  Jan Awaaz MP Command Center <span className="font-normal opacity-60">/ सांसद कमांड सेंटर</span>
                </h1>
                <p className="text-xs text-[#5D4037] font-medium tracking-wide">
                  Constituency Intelligence Dashboard / क्षेत्र विश्लेषण डैशबोर्ड
                </p>
              </div>
            </div>
          </div>
          <div className="flex flex-col items-end">
            <select 
              value={mpLanguage}
              onChange={(e) => setMpLanguage(e.target.value)}
              className="bg-[#FDF6E3] border border-[#E8DCC8] rounded-md px-3 py-1.5 text-sm font-bold text-[#3E2723] outline-none focus:border-[#FF9933]"
            >
              <option value="English">English</option>
              <option value="Hindi">हिंदी (Hindi)</option>
            </select>
            <p className="text-[10px] text-slate-500 mt-1">Full translation available for English and Hindi</p>
          </div>
        </div>
      </header>

      <main className="max-w-7xl mx-auto p-4 sm:p-8">
        
        {/* STATS BAR */}
        <div className="grid grid-cols-2 md:grid-cols-4 gap-4 mb-8">
          <div className="bg-[#FF9933] text-white p-5 rounded-2xl shadow-sm relative overflow-hidden">
            <div className="absolute top-0 right-0 p-4 opacity-20"><MessageSquare className="w-12 h-12" /></div>
            <p className="text-sm font-bold opacity-90 uppercase tracking-wider">Total Complaints</p>
            <p className="text-3xl font-black mt-1">{stats.total}</p>
          </div>
          <div className="bg-[#1A237E] text-white p-5 rounded-2xl shadow-sm relative overflow-hidden">
            <div className="absolute top-0 right-0 p-4 opacity-20"><Clock className="w-12 h-12" /></div>
            <p className="text-sm font-bold opacity-90 uppercase tracking-wider">Today's Complaints</p>
            <p className="text-3xl font-black mt-1">{stats.today}</p>
          </div>
          <div className="bg-[#C62828] text-white p-5 rounded-2xl shadow-sm relative overflow-hidden">
            <div className="absolute top-0 right-0 p-4 opacity-20"><AlertTriangle className="w-12 h-12" /></div>
            <p className="text-sm font-bold opacity-90 uppercase tracking-wider">Critical+High Urgency</p>
            <p className="text-3xl font-black mt-1">{stats.criticalHigh}</p>
          </div>
          <div className="bg-[#2E7D32] text-white p-5 rounded-2xl shadow-sm relative overflow-hidden">
            <div className="absolute top-0 right-0 p-4 opacity-20"><Target className="w-12 h-12" /></div>
            <p className="text-sm font-bold opacity-90 uppercase tracking-wider">Pending Review</p>
            <p className="text-3xl font-black mt-1">{stats.pending}</p>
          </div>
        </div>

        {/* TABS */}
        <div className="flex gap-2 border-b border-[#E8DCC8] mb-6 overflow-x-auto hide-scrollbar">
          <button onClick={() => setActiveTab('live')} className={`px-4 py-2 font-bold text-sm whitespace-nowrap transition border-b-2 ${activeTab === 'live' ? 'border-[#1A237E] text-[#1A237E]' : 'border-transparent text-slate-500 hover:text-[#3E2723]'}`}>
            📋 Live Feed / लाइव फीड
          </button>
          <button onClick={() => setActiveTab('analytics')} className={`px-4 py-2 font-bold text-sm whitespace-nowrap transition border-b-2 ${activeTab === 'analytics' ? 'border-[#1A237E] text-[#1A237E]' : 'border-transparent text-slate-500 hover:text-[#3E2723]'}`}>
            📊 Analytics / विश्लेषण
          </button>
          <button onClick={() => setActiveTab('map')} className={`px-4 py-2 font-bold text-sm whitespace-nowrap transition border-b-2 ${activeTab === 'map' ? 'border-[#1A237E] text-[#1A237E]' : 'border-transparent text-slate-500 hover:text-[#3E2723]'}`}>
            🗺️ Hotspot Map / हॉटस्पॉट मैप
          </button>
        </div>

        {/* TAB CONTENTS */}
        
      </main>
      {/* Fullscreen Photo Modal */}
      {fullscreenPhoto && (
        <div className="fixed inset-0 bg-black/90 z-50 flex flex-col items-center justify-center p-4">
          <button onClick={() => setFullscreenPhoto(null)} className="absolute top-6 right-6 text-white font-bold bg-white/20 hover:bg-white/40 rounded-full px-4 py-2 transition z-50 backdrop-blur">
            Close
          </button>
          <img src={fullscreenPhoto.photo_url} className="max-w-full max-h-[80vh] object-contain rounded shadow-2xl mb-4" />
          {fullscreenPhoto.photo_analysis && (
            <div className="bg-white/10 backdrop-blur p-4 rounded-xl max-w-2xl text-white/90 text-sm">
               <p className="font-bold text-white mb-2">📸 AI Photo Analysis</p>
               <p>{fullscreenPhoto.photo_analysis.description}</p>
               {fullscreenPhoto.photo_analysis.safety_concern && <p className="text-red-400 font-bold mt-2">🚨 Safety Concern Detected</p>}
            </div>
          )}
        </div>
      )}
    </div>
  );
}
